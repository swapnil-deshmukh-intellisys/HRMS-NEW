generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName @unique
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  passwordHash       String
  roleId             Int
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  googleId           String?            @unique
  googleRefreshToken String?
  isGoogleLinked     Boolean            @default(false)
  employee           Employee?
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  todos              Todo[]
  role               Role               @relation(fields: [roleId], references: [id])

  @@index([roleId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  payload   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  code      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id                                Int                               @id @default(autoincrement())
  userId                            Int                               @unique
  employeeCode                      String                            @unique
  firstName                         String
  lastName                          String
  phone                             String?
  gender                            String?
  departmentId                      Int
  managerId                         Int?
  joiningDate                       DateTime
  employmentStatus                  EmploymentStatus                  @default(ACTIVE)
  isActive                          Boolean                           @default(true)
  deletedAt                         DateTime?
  createdAt                         DateTime                          @default(now())
  updatedAt                         DateTime                          @updatedAt
  jobTitle                          String?
  points                            Int                               @default(0)
  annualPackageLpa                  Float?
  grossMonthlySalary                Float?
  basicMonthlySalary                Float?
  isOnProbation                     Boolean                           @default(false)
  probationEndDate                  DateTime?
  panCardNumber                     String?
  dateOfBirth                       DateTime?
  maritalStatus                     String?
  employmentType                    String?                           @default("FULL_TIME")
  internshipType                    String?
  stipend                           Float?
  profilePictureUrl                 String?
  announcements                     Announcement[]                    @relation("AnnouncementCreator")
  attendances                       Attendance[]
  attendanceRegularizationRequests  AttendanceRegularizationRequest[] @relation("AttendanceRegularizationRequester")
  reviewedAttendanceRegularizations AttendanceRegularizationRequest[] @relation("AttendanceRegularizationReviewer")
  breakSessions                     BreakSession[]
  department                        Department                        @relation(fields: [departmentId], references: [id])
  manager                           Employee?                         @relation("EmployeeManager", fields: [managerId], references: [id])
  teamMembers                       Employee[]                        @relation("EmployeeManager")
  user                              User                              @relation(fields: [userId], references: [id])
  capabilities                      EmployeeCapability[]
  teamLeads                         EmployeeTeamLeadScope[]           @relation("TeamLeadScopeMember")
  scopedTeamMembers                 EmployeeTeamLeadScope[]           @relation("TeamLeadScopeLeader")
  approvedIncentives                Incentive[]                       @relation("IncentiveApprover")
  incentives                        Incentive[]
  leaveBalances                     LeaveBalance[]
  leaveRequests                     LeaveRequest[]                    @relation("LeaveRequester")
  hrReviewedLeaves                  LeaveRequest[]                    @relation("LeaveHrApprover")
  managerReviewedLeaves             LeaveRequest[]                    @relation("LeaveManagerApprover")
  medicalProofReviewedLeaves        LeaveRequest[]                    @relation("LeaveMedicalProofReviewer")
  overtimeSessions                  OvertimeSession[]
  verifiedOvertimeSessions          OvertimeSession[]                 @relation("OvertimeVerifier")
  payrollRecords                    PayrollRecord[]
  outlookEmails                     OutlookEmail[]                    @relation("EmployeeOutlookEmails")
  createdManagerTasks               ManagerTask[]                     @relation("ManagerTaskCreator")
  assignedManagerTasks              ManagerTask[]                     @relation("ManagerTaskAssignee")
  completedManagerTasks             ManagerTask[]                     @relation("ManagerTaskCompleter")
  generalTaskCompletions            GeneralTaskCompletion[]
  pointHistory                      PointHistory[]                    @relation("EmployeePointHistory")
  givenPointHistory                 PointHistory[]                    @relation("GivenPointHistory")
  employeeDisputes                  PointsDisputeTicket[]             @relation("EmployeeDisputes")
  resolvedDisputes                  PointsDisputeTicket[]             @relation("ResolvedDisputes")
  documents                         EmployeeDocument[]                @relation("EmployeeDocuments")
  salesRecords                      SalesRecord[]                     @relation("EmployeeSalesRecords")
  desktopActivityLogs               DesktopActivityLog[]
  shiftId                           Int?
  shift                             Shift?                            @relation(fields: [shiftId], references: [id])

  @@index([departmentId])
  @@index([managerId])
  @@index([shiftId])
}

model EmployeeCapability {
  id         Int                    @id @default(autoincrement())
  employeeId Int
  capability EmployeeCapabilityType
  createdAt  DateTime               @default(now())
  employee   Employee               @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, capability])
  @@index([employeeId])
}

model EmployeeTeamLeadScope {
  id           Int      @id @default(autoincrement())
  teamLeaderId Int
  employeeId   Int
  createdAt    DateTime @default(now())
  employee     Employee @relation("TeamLeadScopeMember", fields: [employeeId], references: [id])
  teamLeader   Employee @relation("TeamLeadScopeLeader", fields: [teamLeaderId], references: [id])

  @@unique([teamLeaderId, employeeId])
  @@index([teamLeaderId])
  @@index([employeeId])
}

model Attendance {
  id             Int              @id @default(autoincrement())
  employeeId     Int
  attendanceDate DateTime
  checkInTime    DateTime?
  checkOutTime   DateTime?
  workedMinutes  Int              @default(0)
  status         AttendanceStatus @default(PRESENT)
  todaysUpdate   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isLate         Boolean          @default(false)
  lateByMinutes  Int              @default(0)
  penaltyMinutes Int              @default(0)
  employee       Employee         @relation(fields: [employeeId], references: [id])
  breakSessions  BreakSession[]

  @@unique([employeeId, attendanceDate])
  @@index([employeeId])
  @@index([attendanceDate])
}

model BreakSession {
  id              Int        @id @default(autoincrement())
  attendanceId    Int
  employeeId      Int
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  attendance      Attendance @relation(fields: [attendanceId], references: [id])
  employee        Employee   @relation(fields: [employeeId], references: [id])

  @@index([attendanceId])
  @@index([employeeId])
}

model AttendanceRegularizationRequest {
  id                   Int                            @id @default(autoincrement())
  employeeId           Int
  attendanceDate       DateTime
  proposedCheckInTime  DateTime?
  proposedCheckOutTime DateTime?
  reason               String
  status               AttendanceRegularizationStatus @default(PENDING)
  reviewedById         Int?
  reviewedAt           DateTime?
  rejectionReason      String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  employee             Employee                       @relation("AttendanceRegularizationRequester", fields: [employeeId], references: [id])
  reviewedBy           Employee?                      @relation("AttendanceRegularizationReviewer", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
}

model LeaveType {
  id                          Int                 @id @default(autoincrement())
  name                        String              @unique
  code                        String              @unique
  defaultDaysPerYear          Int
  isActive                    Boolean             @default(true)
  createdAt                   DateTime            @default(now())
  allocationMode              LeaveAllocationMode @default(YEARLY)
  quarterlyAllocationDays     Float?
  carryForwardAllowed         Boolean             @default(false)
  carryForwardCap             Float?
  requiresAttachmentAfterDays Float?
  deductFullQuotaOnApproval   Boolean             @default(false)
  maxUsagesPerYear            Int?
  policyEffectiveFromYear     Int?
  balances                    LeaveBalance[]
  requests                    LeaveRequest[]
}

model LeaveBalance {
  id                   Int       @id @default(autoincrement())
  employeeId           Int
  leaveTypeId          Int
  year                 Int
  allocatedDays        Float
  usedDays             Float     @default(0)
  remainingDays        Float
  updatedAt            DateTime  @updatedAt
  visibleDays          Float     @default(0)
  carryForwardDays     Float     @default(0)
  lastQuarterProcessed Int?
  employee             Employee  @relation(fields: [employeeId], references: [id])
  leaveType            LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id                          Int                @id @default(autoincrement())
  employeeId                  Int
  leaveTypeId                 Int
  startDate                   DateTime
  endDate                     DateTime
  totalDays                   Float
  reason                      String
  status                      LeaveStatus        @default(PENDING)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  isUnpaid                    Boolean            @default(false)
  paidDays                    Float
  unpaidDays                  Float              @default(0)
  attachmentMime              String?
  attachmentName              String?
  attachmentPath              String?
  startDayDuration            LeaveDurationType  @default(FULL_DAY)
  endDayDuration              LeaveDurationType  @default(FULL_DAY)
  managerApprovalStatus       ApprovalStepStatus @default(PENDING)
  managerApprovedById         Int?
  managerApprovedAt           DateTime?
  managerRejectionReason      String?
  hrApprovalStatus            ApprovalStepStatus @default(PENDING)
  hrApprovedById              Int?
  hrApprovedAt                DateTime?
  hrRejectionReason           String?
  deductedDays                Float?
  fullQuotaDeducted           Boolean            @default(false)
  medicalProofRequired        Boolean            @default(false)
  medicalProofDueAt           DateTime?
  medicalProofSubmittedAt     DateTime?
  medicalProofStatus          MedicalProofStatus @default(NOT_REQUIRED)
  medicalProofReviewedAt      DateTime?
  medicalProofReviewedById    Int?
  medicalProofRejectionReason String?
  employee                    Employee           @relation("LeaveRequester", fields: [employeeId], references: [id])
  hrApprovedBy                Employee?          @relation("LeaveHrApprover", fields: [hrApprovedById], references: [id])
  leaveType                   LeaveType          @relation(fields: [leaveTypeId], references: [id])
  managerApprovedBy           Employee?          @relation("LeaveManagerApprover", fields: [managerApprovedById], references: [id])
  medicalProofReviewedBy      Employee?          @relation("LeaveMedicalProofReviewer", fields: [medicalProofReviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([medicalProofStatus])
}

model PayrollRecord {
  id         Int           @id @default(autoincrement())
  employeeId Int
  month      Int
  year       Int
  salary     Decimal       @db.Decimal(10, 2)
  status     PayrollStatus @default(DRAFT)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([employeeId])
}

model OvertimeSession {
  id              Int            @id @default(autoincrement())
  employeeId      Int
  date            DateTime
  startTime       DateTime
  endTime         DateTime?
  duration        Int?
  reason          String?
  status          OvertimeStatus @default(ACTIVE)
  verifiedBy      Int?
  verifiedAt      DateTime?
  rejectionReason String?
  isPaid          Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  employee        Employee       @relation(fields: [employeeId], references: [id])
  verifier        Employee?      @relation("OvertimeVerifier", fields: [verifiedBy], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([status])
  @@index([date])
}

model Incentive {
  id              Int             @id @default(autoincrement())
  employeeId      Int
  type            IncentiveType
  amount          Decimal         @db.Decimal(10, 2)
  reason          String
  description     String?
  month           Int
  year            Int
  status          IncentiveStatus @default(PENDING)
  approvedBy      Int?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  approver        Employee?       @relation("IncentiveApprover", fields: [approvedBy], references: [id])
  employee        Employee        @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([month, year])
  @@index([type])
}

model CalendarException {
  id          Int                   @id @default(autoincrement())
  date        DateTime              @unique
  type        CalendarExceptionType
  name        String?
  description String?
  createdById Int
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([date])
  @@index([type])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  priority    String   @default("NORMAL")
  createdById Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Employee @relation("AnnouncementCreator", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([isActive])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

model NotificationOutbox {
  id        Int      @id @default(autoincrement())
  type      String
  payload   Json
  status    String   @default("PENDING")
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum RoleName {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum AttendanceRegularizationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MedicalProofStatus {
  NOT_REQUIRED
  PENDING_UPLOAD
  PENDING_HR_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum LeaveDurationType {
  FULL_DAY
  HALF_DAY
}

enum LeaveAllocationMode {
  YEARLY
  QUARTERLY
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

enum EmployeeCapabilityType {
  TEAM_LEAD
}

enum OvertimeStatus {
  ACTIVE
  APPROVED
  COMPLETED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum IncentiveType {
  PERFORMANCE_BONUS
  PROJECT_BONUS
  REFERRAL_BONUS
  ATTENDANCE_BONUS
  SPECIAL_ACHIEVEMENT
  OTHER
}

enum IncentiveStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CalendarExceptionType {
  HOLIDAY
  WORKING_SATURDAY
}

model Todo {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  isCompleted Boolean  @default(false)
  priority    String   @default("NORMAL")
  reminderTime DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model OutlookEmail {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  clientId  Int?
  client    Client?    @relation(fields: [clientId], references: [id])
  employees Employee[] @relation("EmployeeOutlookEmails")
  salesRecords SalesRecord[] @relation("OutlookSalesRecords")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Client {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  code      String         @unique
  emails    OutlookEmail[]
  createdAt DateTime       @default(now())
}

model ManagerTask {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  creatorId     Int
  employeeId    Int?      // Null if general task visible to all
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById Int?
  revertReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator     Employee  @relation("ManagerTaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  employee    Employee? @relation("ManagerTaskAssignee", fields: [employeeId], references: [id], onDelete: Cascade)
  completedBy Employee? @relation("ManagerTaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completions GeneralTaskCompletion[]

  @@index([creatorId])
  @@index([employeeId])
  @@index([completedById])
}

model GeneralTaskCompletion {
  id          Int         @id @default(autoincrement())
  taskId      Int
  employeeId  Int
  completedAt DateTime    @default(now())

  task        ManagerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
  @@index([taskId])
  @@index([employeeId])
}

model PointHistory {
  id            Int                  @id @default(autoincrement())
  employeeId    Int
  amount        Int
  reason        String
  mode          String               // "add", "subtract", "set"
  givenById     Int?
  createdAt     DateTime             @default(now())
  
  employee      Employee             @relation("EmployeePointHistory", fields: [employeeId], references: [id])
  givenBy       Employee?            @relation("GivenPointHistory", fields: [givenById], references: [id])
  disputeTicket PointsDisputeTicket?

  @@index([employeeId])
  @@index([givenById])
}

enum PointsDisputeStatus {
  PENDING
  APPROVED
  REJECTED
}

model PointsDisputeTicket {
  id             Int                 @id @default(autoincrement())
  pointHistoryId Int                 @unique
  employeeId     Int
  reason         String
  status         PointsDisputeStatus @default(PENDING)
  hrRemarks      String?
  resolvedById   Int?
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  pointHistory   PointHistory        @relation(fields: [pointHistoryId], references: [id], onDelete: Cascade)
  employee       Employee            @relation("EmployeeDisputes", fields: [employeeId], references: [id], onDelete: Cascade)
  resolvedBy     Employee?           @relation("ResolvedDisputes", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([resolvedById])
}

model EmployeeDocument {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  name         String
  originalName String
  filePath     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  employee     Employee @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model SalesRecord {
  id             Int          @id @default(autoincrement())
  employeeId     Int
  outlookEmailId Int
  amount         Float        @default(0)
  month          Int          // 1-12
  year           Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee     Employee     @relation("EmployeeSalesRecords", fields: [employeeId], references: [id], onDelete: Cascade)
  outlookEmail OutlookEmail @relation("OutlookSalesRecords", fields: [outlookEmailId], references: [id], onDelete: Cascade)

  @@unique([employeeId, outlookEmailId, month, year])
  @@index([employeeId])
  @@index([outlookEmailId])
}

model SalesTarget {
  id        Int      @id @default(autoincrement())
  month     Int
  year      Int
  target    Float    @default(50000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model GoogleSheetConfig {
  id           Int      @id @default(autoincrement())
  year         Int      @unique
  attendanceId String?  
  updatesId    String?  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GoogleSheetSyncQueue {
  id          Int      @id @default(autoincrement())
  entityType  String   // "ATTENDANCE"
  entityId    Int
  action      String   // "UPSERT"
  status      String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  retryCount  Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
}

model DesktopActivityLog {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  eventType    String   // "LOCK", "UNLOCK", "SLEEP", "WAKE", "SHUTDOWN", "IDLE_START", "IDLE_END"
  timestamp    DateTime
  ipAddress    String?
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([eventType])
  @@index([timestamp])
}

model Shift {
  id                 Int        @id @default(autoincrement())
  name               String     @unique
  startTime          String     // 24h format, e.g. "09:00"
  endTime            String     // 24h format, e.g. "18:00"
  requiredMinutes    Int        @default(540)
  gracePeriodMinutes Int        @default(15)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  employees          Employee[]
}
