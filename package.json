{
  "name": "hrms3",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend",
    "e2e"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build",
    "lint": "npm --workspace backend run lint && npm --workspace frontend run lint",
    "test": "npm --workspace backend run test && npm --workspace frontend run test",
    "test:backend": "npm --workspace backend run test",
    "test:frontend": "npm --workspace frontend run test",
    "test:e2e": "npm --workspace e2e run test",
    "test:e2e:smoke": "npm --workspace e2e run test:smoke",
    "test:e2e:api": "npm --workspace e2e run test:api",
    "sync-excel": "npm --workspace backend run sync-excel"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^24.1.3",
    "vitest": "^1.6.1"
  }
}
