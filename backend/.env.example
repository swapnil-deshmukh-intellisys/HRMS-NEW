PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hrms_v1?schema=public"
JWT_SECRET="change-me"

# Google Workspace Integration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URL="http://localhost:5173/google-callback"
GOOGLE_CHAT_WEBHOOK_URL=""

# Web Push Notifications (Native Desktop Alerts)
# Generate new keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-public-key-here"
VAPID_PRIVATE_KEY="your-private-key-here"
VAPID_SUBJECT="mailto:your-email@domain.com"
