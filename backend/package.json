{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/modules/auth/service.test.ts src/modules/attendance/service.test.ts src/modules/leaves/service.test.ts src/modules/payroll/service.test.ts",
